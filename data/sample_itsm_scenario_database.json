  "troubleshooting_guides": {
    "login_issue": {
      "category": "login_issue",
      "steps": [
        {
          "step_number": 1,
          "instruction": "Confirm the username being used. Ask the caller to spell their username letter by letter. Verify it matches the format firstname.lastname.",
          "expected_outcome": "Username is confirmed correct or corrected."
        },
        {
          "step_number": 2,
          "instruction": "Ask the caller to check their Caps Lock key and try entering their password again slowly.",
          "expected_outcome": "Password entry succeeds or fails again."
        },
        {
          "step_number": 3,
          "instruction": "Ask the caller to try the self-service password reset portal at reset.company.com. They will need to answer their security questions.",
          "expected_outcome": "Password is reset successfully, or the portal is inaccessible."
        },
        {
          "step_number": 4,
          "instruction": "Ask the caller whether they recently changed devices or locations. If so, ask them to check for a multi-factor authentication prompt on their registered device.",
          "expected_outcome": "MFA prompt is found and completed, or no MFA prompt received."
        }
      ]
    },
    "network_connectivity": {
      "category": "network_connectivity",
      "steps": [
        {
          "step_number": 1,
          "instruction": "Ask the caller whether they are on Wi-Fi, Ethernet, or VPN. If Wi-Fi, ask them to forget the network and reconnect to 'CorpNet-5G'.",
          "expected_outcome": "Wi-Fi reconnection succeeds or fails."
        },
        {
          "step_number": 2,
          "instruction": "Ask the caller to open a web browser and navigate to connectivity-check.company.com. Report what they see.",
          "expected_outcome": "Page loads (DNS working) or fails (DNS issue)."
        },
        {
          "step_number": 3,
          "instruction": "If the caller is using VPN, ask them to disconnect from the VPN, restart the VPN client, and reconnect. The VPN client is GlobalConnect.",
          "expected_outcome": "VPN reconnection succeeds or continues to fail."
        },
        {
          "step_number": 4,
          "instruction": "Ask the caller to restart their computer and try connecting again after the full reboot is complete.",
          "expected_outcome": "Connectivity restored after restart, or issue persists."
        }
      ]
    }
  },
